# Primary key (active)
HUNTER_API_KEY=...

# Backup keys (used automatically when rate limited)
HUNTER_API_KEY=...
HUNTER_API_KEY=...
HUNTER_API_KEY=...
HUNTER_API_KEY=...
HUNTER_API_KEY=...

# Rate limiting settings
# Delay between API requests in seconds (default: 2)
RATE_LIMIT_DELAY=2
# Maximum retry attempts when hitting rate limits (default: 3)
MAX_RETRIES=3
# Initial retry delay in seconds (doubles with each retry - exponential backoff)
RETRY_DELAY=5